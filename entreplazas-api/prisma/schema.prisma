generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  apellidos    String
  email        String    @unique
  passwordHash String
  telefono     String?
  rol          Rol       @default(CLIENTE)
  createdAt    DateTime  @default(now())
  negocios     Negocio[]
  reservas     Reserva[]
}

model Negocio {
  id              Int       @id @default(autoincrement())
  propietarioId   Int
  propietario     Usuario   @relation(fields: [propietarioId], references: [id])
  nombre          String
  descripcion     String?
  direccion       String?
  ciudad          String?
  telefono        String?
  imagenUrl       String?
  horarioApertura String?
  horarioCierre   String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  mensajeAviso    String?
  mesas           Mesa[]
  reservas        Reserva[]
  menus           Menu[]
  turnos          Turno[]
  paredes         Pared[]
  diasBloqueados  DiasBloqueado[]
}

model Mesa {
  id        Int       @id @default(autoincrement())
  negocioId Int
  negocio   Negocio   @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  etiqueta  String
  capacidad Int
  posX      Int       @default(0)
  posY      Int       @default(0)
  ancho     Int       @default(80)
  alto      Int       @default(80)
  activa    Boolean   @default(true)
  reservas  Reserva[]
}

model Reserva {
  id             Int           @id @default(autoincrement())
  mesaId         Int
  mesa           Mesa          @relation(fields: [mesaId], references: [id])
  usuarioId      Int
  usuario        Usuario       @relation(fields: [usuarioId], references: [id])
  negocioId      Int
  negocio        Negocio       @relation(fields: [negocioId], references: [id])
  fecha          DateTime      @db.Date
  horaInicio     String?
  nombreContacto String?
  numPersonas    Int?
  estado         EstadoReserva @default(PENDIENTE)
  createdAt      DateTime      @default(now())
  turnoId        Int?
}

model Menu {
  id        Int      @id @default(autoincrement())
  negocioId Int
  negocio   Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  nombre    String
  activo    Boolean  @default(true)
  platos    Plato[]
}

model Pared {
  id        Int     @id @default(autoincrement())
  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  x1        Int
  y1        Int
  x2        Int
  y2        Int
  grosor    Int     @default(8)
}

model Turno {
  id         Int     @id @default(autoincrement())
  negocioId  Int
  negocio    Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  nombre     String
  horaInicio String
  horaFin    String
  activo     Boolean @default(true)
  diasSemana String? @default("1,2,3,4,5,6,0")
}

model DiasBloqueado {
  id        Int      @id @default(autoincrement())
  negocioId Int
  negocio   Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  fecha     DateTime @db.Date
  motivo    String?
}

model Plato {
  id          Int     @id @default(autoincrement())
  menuId      Int
  menu        Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  precio      Float?
  categoria   String?
  disponible  Boolean @default(true)
  imagenUrl   String?
}

enum Rol {
  CLIENTE
  HOSTELERO
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}